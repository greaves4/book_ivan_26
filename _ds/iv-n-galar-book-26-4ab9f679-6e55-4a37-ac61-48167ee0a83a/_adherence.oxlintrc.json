{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": []
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Instrument Serif|Space Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Instrument Serif, Space Grotesk, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-hover",
      "--ash-300",
      "--ash-500",
      "--ash-700",
      "--ash-900",
      "--bg-canvas",
      "--bg-inverse",
      "--bone",
      "--dur-fast",
      "--dur-med",
      "--dur-slow",
      "--ease-in",
      "--ease-out",
      "--font-display",
      "--font-mono",
      "--font-ui",
      "--fs-display-lg",
      "--fs-display-md",
      "--fs-display-sm",
      "--fs-display-xl",
      "--fs-mono-sm",
      "--fs-mono-xs",
      "--fs-ui-lg",
      "--fs-ui-md",
      "--fs-ui-sm",
      "--ink",
      "--ink-soft",
      "--lh-body",
      "--lh-snug",
      "--lh-tight",
      "--orange",
      "--orange-bright",
      "--orange-deep",
      "--paper-100",
      "--paper-200",
      "--paper-50",
      "--radius-0",
      "--radius-1",
      "--radius-pill",
      "--rule",
      "--rule-hair",
      "--rule-thick",
      "--scrim",
      "--sp-1",
      "--sp-2",
      "--sp-3",
      "--sp-4",
      "--sp-5",
      "--sp-6",
      "--sp-7",
      "--sp-8",
      "--sp-9",
      "--text-inverse",
      "--text-muted",
      "--text-primary",
      "--tracking-display",
      "--tracking-mono",
      "--tracking-ui",
      "--white"
    ],
    "tokenKinds": {
